# Akshara Vision environment template.
# Copy this file to `.env` for local development:
# cp .env.example .env
#
# Keep `.env` private. It is ignored by git.

# Optional cloud providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional local OpenAI-compatible runtime
# LM Studio usually uses http://localhost:1234/v1
# Jan usually uses http://localhost:1337/v1
# llama.cpp server often uses http://localhost:8080/v1
AKSHARA_OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
AKSHARA_OPENAI_COMPATIBLE_API_KEY=

# Optional config location override
AKSHARA_CONFIG_HOME=
